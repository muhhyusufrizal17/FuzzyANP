   "source": [
    "import matplotlib.pyplot as plt\n",
    "import pandas as pd\n",
    "\n",
    "# Data (dari tabel kamu)\n",
    "anp = pd.DataFrame({\n",
    "    \"n_node\": [5, 10, 15, 20],\n",
    "    \"pm_median_s\": [0.021290, 0.059844, 0.019016, 0.012055],\n",
    "})\n",
    "\n",
    "fanp = pd.DataFrame({\n",
    "    \"n_responden\": [10, 30, 50, 75, 100],\n",
    "    \"median_time_s\": [0.004470, 0.006240, 0.008864, 0.006171, 0.005886],\n",
    "})\n",
    "\n",
    "plt.figure()\n",
    "\n",
    "# ANP Classic\n",
    "plt.plot(\n",
    "    anp[\"n_node\"],\n",
    "    anp[\"pm_median_s\"],\n",
    "    marker=\"o\",\n",
    "    label=\"ANP Classic\"\n",
    ")\n",
    "\n",
    "# Fuzzy ANP (Chang)\n",
    "plt.plot(\n",
    "    fanp[\"n_responden\"],\n",
    "    fanp[\"median_time_s\"],\n",
    "    marker=\"s\",\n",
    "    label=\"Fuzzy ANP\"\n",
    ")\n",
    "\n",
    "plt.title(\"Complexity Comparison (Empirical) between ANP Classic and Fuzzy ANP\")\n",
    "plt.xlabel(\"Problem Size (Node / Respondent)\")\n",
    "plt.ylabel(\"Execution Time (seconds)\")\n",
    "plt.legend()\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
   ]
  }
 ],
